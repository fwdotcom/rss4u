#!/usr/bin/env sh
set -e

repo_root="$(git rev-parse --show-toplevel)"

if command -v pwsh >/dev/null 2>&1; then
	pwsh -NoProfile -File "$repo_root/build/scripts/common/sync-web-version.ps1"
elif command -v powershell >/dev/null 2>&1; then
	powershell -NoProfile -ExecutionPolicy Bypass -File "$repo_root/build/scripts/common/sync-web-version.ps1"
else
	echo "No PowerShell runtime found (pwsh/powershell)." >&2
	exit 1
fi

git add public/index.html
