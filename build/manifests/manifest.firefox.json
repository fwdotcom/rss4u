{
  "manifest_version": 3,
  "name": "rss4u",
  "short_name": "rss4u",
  "description": "A lightweight RSS/Atom reader that runs in your browser.",
  "version": "1.0.0",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "Open rss4u",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rss4u@fwdotcom.github.io",
      "strict_min_version": "121.0"
    }
  }
}
